# Backend-specific .gitignore
# This file complements the root .gitignore

# Python virtual environment
venv/
.venv/
env/
ENV/

# Environment variables (contains AWS keys, API keys, etc.)
.env
.env.local
.env.production
.env.staging

# Logs
*.log
predictions.log
logs/

# Satellite data (downloaded/generated data, not core app data)
nasa_data/
satellite_data/

# Cache and temporary files
__pycache__/
*.pyc
*.pyo
*.pyd
.cache/
.pytest_cache/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Test coverage
.coverage
htmlcov/
coverage.xml

# AWS credentials
.aws/

# Azure storage
__blobstorage__

# Database files
*.db
*.sqlite
*.sqlite3

# Backup files
*.bak
*.backup
models/